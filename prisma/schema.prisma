generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RegionCode {
  EUROPE
  ASIA
  MIDDLE_EAST
  GLOBAL
  NORTH_AMERICA
  SOUTH_AMERICA
  AFRICA
  OCEANIA
}

enum PackageScope {
  COUNTRY
  REGION
  GLOBAL
}

enum UsageType {
  LIGHT
  STANDARD
  HEAVY
}

enum CurrencyCode {
  USD
  EUR
  GBP
}

enum OrderStatus {
  PENDING
  PAID
  PROVISIONING
  PROVISIONING_FAILED
  DELIVERED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  GENERATED
  SENT
  FAILED
}

enum DeliveryChannel {
  EMAIL
  DASHBOARD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum AnalyticsEventName {
  COUNTRY_VIEW
  PACKAGE_SELECT
  CHECKOUT_START
  PAYMENT_SUCCESS
  ESIM_DELIVERED
}

model Region {
  id        String     @id @default(cuid())
  code      RegionCode @unique
  name      String
  slug      String     @unique
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  countries Country[]
  packages  Package[]

  @@index([active, name])
}

model Country {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  isoCode             String   @unique
  flag                String
  regionId            String
  description         String
  heroTitle           String
  tagline             String
  deviceCompatibility String
  activationPolicy    String
  refundPolicy        String
  faq                 Json
  seoTitle            String?
  seoDescription      String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  region   Region           @relation(fields: [regionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  networks CountryNetwork[]
  packages Package[]

  @@index([regionId, active, name])
  @@index([active, slug])
}

model CountryNetwork {
  id        String   @id @default(cuid())
  countryId String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([countryId, name])
  @@index([countryId, active])
}

model Package {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  countryId           String?
  regionId            String?
  scope               PackageScope @default(COUNTRY)
  dataGb              Decimal      @db.Decimal(10, 2)
  validityDays        Int
  price               Decimal      @db.Decimal(10, 2)
  currency            CurrencyCode @default(USD)
  usageType           UsageType
  popular             Boolean      @default(false)
  active              Boolean      @default(true)
  description         String
  networkSummary      String[]
  deviceCompatibility String
  activationPolicy    String
  refundPolicy        String
  installHeadline     String
  faq                 Json
  sortOrder           Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  country         Country?          @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  region          Region?           @relation(fields: [regionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  providerPlanMap ProviderPlanMap?
  orders          Order[]

  @@index([countryId, active, popular, sortOrder])
  @@index([regionId, active, popular, sortOrder])
  @@index([scope, active, popular, sortOrder])
  @@index([active, slug])
}

model Provider {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  apiBaseUrl String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  planMaps ProviderPlanMap[]

  @@index([active, name])
}

model ProviderPlanMap {
  id               String   @id @default(cuid())
  providerId       String
  packageId        String   @unique
  providerPlanCode String
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([providerId, packageId])
  @@unique([providerId, providerPlanCode])
  @@index([providerId, active])
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  referralCode   String?  @unique
  referredByCode String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]

  @@index([createdAt])
}

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique
  description       String?
  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(10, 2)
  expiryDate        DateTime?
  maxUses           Int?
  active            Boolean      @default(true)
  usesCount         Int          @default(0)
  minimumOrderValue Decimal?     @db.Decimal(10, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  orders Order[]

  @@index([active, expiryDate])
}

model Order {
  id                    String       @id @default(cuid())
  userId                String?
  email                 String
  packageId             String
  couponId              String?
  referralCodeUsed      String?
  affiliateCode         String?
  status                OrderStatus  @default(PENDING)
  price                 Decimal      @db.Decimal(10, 2)
  currency              CurrencyCode @default(USD)
  stripeSessionId       String?      @unique
  stripePaymentIntentId String?      @unique
  paidAt                DateTime?
  checkoutFingerprint   String?      @unique
  subtotalAmount        Decimal      @db.Decimal(10, 2)
  discountAmount        Decimal      @db.Decimal(10, 2) @default(0)
  taxAmount             Decimal      @db.Decimal(10, 2) @default(0)
  totalAmount           Decimal      @db.Decimal(10, 2)
  providerOrderId       String?      @unique
  qrCodeUrl             String?
  activationCode        String?
  manualCode            String?
  failureReason         String?
  metadata              Json?
  abandonedEmailSentAt  DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  package    Package          @relation(fields: [packageId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  coupon     Coupon?          @relation(fields: [couponId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deliveries Delivery[]
  events     AnalyticsEvent[]

  @@index([packageId, createdAt])
  @@index([email, createdAt])
  @@index([status, createdAt])
}

model Delivery {
  id             String          @id @default(cuid())
  orderId        String
  externalOrderId String?
  email          String
  channel        DeliveryChannel
  qrCodeUrl      String?
  activationCode String?
  manualCode     String?
  iccid          String?
  smdpAddress    String?
  status         DeliveryStatus  @default(PENDING)
  lastError      String?
  instructions   Json?
  deliveredAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId, createdAt])
  @@index([status, createdAt])
}

model AnalyticsEvent {
  id          String             @id @default(cuid())
  eventName   AnalyticsEventName
  orderId     String?
  countrySlug String?
  packageSlug String?
  path        String?
  payload     Json?
  createdAt   DateTime           @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([eventName, createdAt])
  @@index([countrySlug, createdAt])
  @@index([packageSlug, createdAt])
}
